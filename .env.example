# Supabase — copy to .env.local and fill with your project's values
# Dashboard: Project Settings > API Keys
NEXT_PUBLIC_SUPABASE_URL=
# Publishable key (sb_publishable_...), safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional paid profile-photo AI review. Keep disabled in local development
# unless actively testing the review flow.
PROFILE_PHOTO_REVIEW_ENABLED=false
# Server-only: required when PROFILE_PHOTO_REVIEW_ENABLED=true.
OPENAI_API_KEY=
# Optional override; defaults to gpt-5.5.
OPENAI_PHOTO_REVIEW_MODEL=

# Local phone testing only: your machine's LAN IP (e.g. 192.168.1.67), so
# Next.js allows the phone to load dev assets. Leave empty otherwise.
DEV_LAN_ORIGIN=

# Public origin used to build the venue check-in URL encoded in each QR code
# (admin dashboard). Defaults to window.location.origin when empty, so set it to
# the deployed URL (e.g. https://paramour.app) before printing real QR codes.
NEXT_PUBLIC_SITE_URL=
